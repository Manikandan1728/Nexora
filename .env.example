# Nexora — Telegram AI Knowledge Retrieval Platform
# Copy to .env and fill in values as needed.

# ---------------------------------------------------------
# API Server Configuration
# ---------------------------------------------------------
NEXORA_API_HOST=0.0.0.0
NEXORA_API_PORT=8000
NEXORA_API_LOG_LEVEL=INFO
NEXORA_API_VERSION=8.0.0

# ---------------------------------------------------------
# Storage & Database
# ---------------------------------------------------------
# PostgreSQL configuration (Docker Compose default)
POSTGRES_USER=nexora
POSTGRES_PASSWORD=nexora_secret_password
POSTGRES_DB=nexora
# Un-comment the next line to enable PostgreSQL persistence.
# If commented, Nexora falls back to SQLite at NEXORA_TELEGRAM_DB_PATH
NEXORA_DATABASE_URL=postgresql://nexora:nexora_secret_password@postgres:5432/nexora

# Fallback SQLite DB path (if PostgreSQL is not used)
NEXORA_TELEGRAM_DB_PATH=data/storage/nexora_telegram.db

# Vector Storage Configuration
NEXORA_VECTORS_ROOT=data/vectors

# Media Storage Configuration
NEXORA_MEDIA_ROOT=data/media
# NEXORA_DELETE_LOCAL_MEDIA_ON_DELETE=false

# ---------------------------------------------------------
# LLM Provider Configuration
# ---------------------------------------------------------
# Supported: "ollama" or "openai"
NEXORA_LLM_PROVIDER=ollama
# NEXORA_LLM_MODEL=llama3
# NEXORA_LLM_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=sk-...

# ---------------------------------------------------------
# Secret Store (Encryption)
# ---------------------------------------------------------
# Generate a secure key: python -m app.security.secrets.generate_key
# The key must be a base64url-encoded 32-byte AES-256 key.
NEXORA_SECRET_STORE_PROVIDER=environment
NEXORA_SECRET_ENCRYPTION_KEY=
NEXORA_SECRET_KEY_ID=dev-key-1
NEXORA_SECRET_ENCRYPTION_VERSION=v1

# ---------------------------------------------------------
# Telegram Configuration (Part 2C)
# ---------------------------------------------------------
# TELEGRAM_MODE determines if we use the mock or real client.
# Options: mock, real (default: mock)
TELEGRAM_MODE=mock

# Required if TELEGRAM_MODE=real
# TELEGRAM_API_ID=123456
# TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Optional customization for Telegram
TELEGRAM_DEVICE_MODEL=Nexora
TELEGRAM_LANG_CODE=en
TELEGRAM_SYSTEM_LANG_CODE=en
